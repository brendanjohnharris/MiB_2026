@Article{Gutierrez2015,
  author           = {Gutiérrez, Esther D. and Cabrera, Juan Luis},
  year = {2015},
  date             = {2015},
  journaltitle     = {Scientific Reports},
  journal     = {Scientific Reports},
  title            = {A neural coding scheme reproducing foraging trajectories},
  doi              = {10.1038/srep18009},
  issn             = {2045-2322},
  number           = {1},
  pages            = {18009},
  volume           = {5},
  abstract         = {The movement of many animals may follow Lévy patterns. The underlying generating neuronal dynamics of such a behavior is unknown. In this paper we show that a novel discovery of multifractality in winnerless competition (WLC) systems reveals a potential encoding mechanism that is translatable into two dimensional superdiffusive Lévy movements. The validity of our approach is tested on a conductance based neuronal model showing WLC and through the extraction of Lévy flights inducing fractals from recordings of rat hippocampus during open field foraging. Further insights are gained analyzing mice motor cortex neurons and non motor cell signals. The proposed mechanism provides a plausible explanation for the neuro-dynamical fundamentals of spatial searching patterns observed in animals (including humans) and illustrates an until now unknown way to encode information in neuronal temporal series.},
  groups           = {Working regime, PhD},
  modificationdate = {2025-11-13T10:12:53},
  refid            = {Gutiérrez2015},
}


