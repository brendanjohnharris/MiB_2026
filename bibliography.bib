  modificationdate = {2025-10-04T12:23:35},
}


@Article{Magdziarz2009,
  author           = {Magdziarz, Marcin},
  year = {2009},
  date             = {2009},
  journaltitle     = {Journal of Statistical Physics},
  journal     = {Journal of Statistical Physics},
  title            = {Langevin Picture of Subdiffusion with Infinitely Divisible Waiting Times},
  doi              = {10.1007/s10955-009-9751-z},
  issn             = {1572-9613},
  number           = {4},
  pages            = {763--772},
  volume           = {135},
  abstract         = {In this paper we study a Langevin approach to modeling of subdiffusion in the presence of time-dependent external forces. We construct a subordinated Langevin process, whose probability density function solves the subdiffusive fractional Fokker-Planck equation. We generalize the results known for the Lévy-stable waiting times to the case of infinitely divisible waiting-time distributions. Our approach provides a complete mathematical description of subdiffusion with time-dependent forces. Moreover, it allows to study the trajectories of the constructed process both analytically and numerically via Monte-Carlo methodology.},
  creationdate     = {2025-10-04T12:23:28},
